# Required: TMDB API key (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: TMDB base URL (default: https://api.themoviedb.org/3)
# TMDB_BASE_URL=https://api.themoviedb.org/3

# Optional: Public site URL for metadata/SEO
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Google Custom Search API for fallback movie images
# Only needed when TMDB is missing poster/backdrop for a movie
# Get credentials at https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here
