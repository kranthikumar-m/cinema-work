# Required: TMDB API key (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_actual_tmdb_api_key

# Optional but recommended: public site URL used in password reset links
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: TMDB base URL (default: https://api.themoviedb.org/3)
# TMDB_BASE_URL=https://api.themoviedb.org/3

# Optional: override the user agent used for Google Images fallback lookups
# GOOGLE_IMAGES_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# Optional in local development: defaults to file:./data/cinema.sqlite when omitted
# In production, set this explicitly to either:
# 1. a persistent SQLite path, or
# 2. your Supabase project URL, for example https://your-project-ref.supabase.co
# DATABASE_URL=file:./data/cinema.sqlite
# DATABASE_URL=https://your-project-ref.supabase.co

# Required when DATABASE_URL points to Supabase
# Use the server-side service role key, never expose it to the client
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional in local dev: defaults to a local-only development secret when omitted
# Set this explicitly in any shared or production environment
# AUTH_SECRET=replace_with_a_long_random_secret

# Optional: bootstrap the first admin account when the database is empty
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=change-me-now
